# Deployment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# Your deployer wallet private key (with 0x prefix)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Sepolia RPC URL (Alchemy or Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY_HERE

# Etherscan API key for contract verification (optional but recommended)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY_HERE

# SentimentOracle contract address on Sepolia (already deployed)
ORACLE_ADDRESS=0xcA374e8bba8bd2BA0Aed26c4d425aA9aa7E058D0

# SentimentGate contract address on Sepolia (deploy with DeployGate.s.sol first)
GATE_ADDRESS=0xYOUR_GATE_ADDRESS_HERE
